<?xml version="1.0" encoding="utf-8"?>
<!-- same as bg game panel, except no vertical padding -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="@color/game_panel_background" />

    <stroke
        android:width="3dp"
        android:color="@color/game_panel_border"/>

    <padding
        android:bottom="0dp"
        android:left="12dp"
        android:right="12dp"
        android:top="0dp" />

    <corners android:radius="15dp" />
</shape>