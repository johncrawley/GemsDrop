<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"

    android:background="@drawable/background_1"
    android:gravity="center"
    android:tileMode="mirror"
    android:layout_height="match_parent">


    <TextView
        android:id="@+id/gameOverTextShadowView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/game_over_text"
        android:textSize="@dimen/game_over_text_size"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textColor="@color/game_over_text"
        android:background="@color/heading_text_background"
        android:shadowColor="@color/colorPrimaryDark"
        android:shadowDx="1"
        android:shadowDy="15"
        android:shadowRadius="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.30" />

    <TextView
        android:id="@+id/gameOverTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/game_over_text"
        android:textSize="@dimen/game_over_text_size"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textColor="@color/game_over_text"
        android:background="@color/heading_text_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.30" />


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/background_final_score"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gameOverTextView">


        <TextView
            android:id="@+id/yourScoreTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/game_over_score_text"
            android:textAlignment="center"
            android:layout_margin="8dp"
            android:textSize="26sp"
            android:textColor="@color/score_text_top"
            android:shadowColor="@color/colorPrimaryDark"
            android:shadowDx="1"
            android:shadowDy="15"
            android:shadowRadius="2"
            app:layout_constraintVertical_bias="0.32" />

        <TextView
            android:id="@+id/scoreText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_margin="8dp"
            android:shadowColor="@color/colorPrimaryDark"
            android:shadowDx="1"
            android:shadowDy="15"
            android:shadowRadius="2"
            android:text="@string/score_placeholder_text"
            android:textAlignment="center"
            android:textColor="@color/score_text_top"
            android:textSize="@dimen/game_over_score_text_size"/>

    </LinearLayout>





</androidx.constraintlayout.widget.ConstraintLayout>