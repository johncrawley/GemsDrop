<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:id="@+id/gemsPreviewLayout"
    android:padding="8dp"
    android:gravity="center"
    android:background="@drawable/background_game_panel">

    <ImageView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:contentDescription="@string/gem_preview_image_content_description"
        android:src="@drawable/jewel_green"/>


    <ImageView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:contentDescription="@string/gem_preview_image_content_description"
        android:src="@drawable/jewel_blue"/>


    <ImageView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:contentDescription="@string/gem_preview_image_content_description"
        android:src="@drawable/jewel_red"/>


</LinearLayout>